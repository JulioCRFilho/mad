{
  "name": "mad",
  "displayName": "Mermaid Auto-Doccing",
  "description": "Extension to automatically generate documentation from Mermaid diagrams in VS Code.",
  "version": "1.7.3",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:php",
    "onLanguage:dart",
    "onLanguage:ruby",
    "onLanguage:swift",
    "onLanguage:kotlin",
    "onLanguage:scala",
    "onLanguage:cpp",
    "onLanguage:c",
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "MAD - Mermaid Auto-Doccing",
      "properties": {
        "mad.disableFormatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Disables automatic formatOnSave when files with MAD tags are opened. Recommended to prevent the auto-formatter from adding spaces in `//@`."
        },
        "mad.showFormatWarning": {
          "type": "boolean",
          "default": true,
          "description": "Shows warning when formatOnSave is enabled and may break MAD tags."
        },
        "mad.server.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the local HTTP server for CLI agent validation (127.0.0.1 only, auto-assigned port)."
        },
        "mad.server.port": {
          "type": "number",
          "default": 0,
          "description": "HTTP server port (0 = auto-assign). Change requires restart."
        }
      }
    },
    "commands": [
      {
        "command": "mad.configureFormatter",
        "title": "MAD: Configurar Auto-Formatter (desabilita formatOnSave)"
      },
      {
        "command": "mad.showLogs",
        "title": "MAD: Show Extension Logs"
      },
      {
        "command": "mad.showServerStatus",
        "title": "MAD: Show Server Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && NODE_PATH=test/mocks node --test test/mad-outputs.test.mjs"
  },
    "dependencies": {
        "mermaid": "^10.0.0"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.0.0"
    },
  "repository": {
    "type": "git",
    "url": "https://github.com/JulioCRFilho/mad.git"
  },
  "icon": "assets/icon.png",
  "publisher": "TheTod",
  "license": "MIT",
  "keywords": [
    "mermaid",
    "diagram",
    "documentation",
    "autodoc",
    "mad",
    "sdd"
  ]
}
