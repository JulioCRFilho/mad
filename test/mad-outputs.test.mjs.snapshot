exports[`01 – Flowchart (01-flowchart-login.ts) > complete snapshot 1`] = `
"graph LR\\n    subgraph Auth\\n        Auth1[\\"Authenticate\\"]\\n        Auth2[\\"Create session\\"]\\n    end\\n    subgraph Dashboard\\n        Dashboard1[\\"Show dashboard\\"]\\n        Dashboard2[\\"Load data\\"]\\n    end\\n    subgraph Entry\\n        Entry1[\\"Handle login\\"]\\n        Entry1.1[\\"Verify 2FA\\"]\\n    end\\n    subgraph Error\\n        Error1[\\"Invalid credentials\\"]\\n        Error2[\\"Too many requests\\"]\\n        Error3[\\"Invalid 2FA\\"]\\n    end\\n    subgraph RateLimiter\\n        RateLimiter1[\\"Check limit\\"]\\n    end\\n    subgraph TwoFactor\\n        TwoFactor1[\\"Challenge 2FA\\"]\\n        TwoFactor2[\\"Validate code\\"]\\n    end\\n    Entry1 -->|Verify 2FA| Entry1.1\\n    Entry1 -->|Check limit| RateLimiter1\\n    Entry1 -->|Authenticate| Auth1\\n    Entry1 -->|Challenge 2FA| TwoFactor1\\n    Entry1 -->|Create session| Auth2\\n    Entry1 -->|Show dashboard| Dashboard1\\n    Entry1 -->|Validate code| TwoFactor2\\n    Dashboard1 -->|Load data| Dashboard2\\n"
`;

exports[`02 – Sequence (02-sequence-api.js) > complete snapshot 1`] = `
"sequenceDiagram\\n    participant Client\\n    participant Gateway\\n    participant AuthMiddleware\\n    Note over Client: Fetch user data\\n    Client->>Gateway: Send authenticated request\\n    Client->>AuthMiddleware: Refresh expired token\\n\\n---\\nsequenceDiagram\\n    participant Gateway\\n    participant AuthMiddleware\\n    participant Server\\n    participant Error\\n    Note over Gateway: Handle incoming request\\n    Gateway->>AuthMiddleware: Validate JWT\\n    Gateway->>Error: Return 429 Too Many Requests\\n    Gateway->>Server: Proxy to user service\\n\\n---\\nsequenceDiagram\\n    participant AuthMiddleware\\n    participant Error\\n    Note over AuthMiddleware: Validate JWT token\\n    AuthMiddleware->>Error: Return 401 Missing token\\n    AuthMiddleware->>Error: Return 401 Invalid token\\n    AuthMiddleware->>Error: Return 403 Forbidden\\n\\n---\\nsequenceDiagram\\n    participant Cache\\n    Note over Cache: Read from cache\\n    Cache->>Cache: Write to Redis\\n\\n---\\nsequenceDiagram\\n    participant Cache\\n    participant Server\\n    participant Database\\n    participant Notification\\n    participant AuditLog\\n    participant Error\\n    Note over Server: Get user by ID\\n    Server->>Cache: Check cache for user\\n    Server->>Database: Query user with address JOIN\\n    Server->>Error: Throw NotFoundError\\n    Server->>Cache: Store user in cache\\n    Server->>Notification: Send welcome email\\n    Server->>AuditLog: Record user fetch\\n    Server->>Database: Update user in transaction\\n    Server->>Cache: Invalidate user cache\\n    Server->>AuditLog: Record user update\\n\\n---\\nsequenceDiagram\\n    participant Database\\n    Note over Database: Query user by ID\\n\\n---\\nsequenceDiagram\\n    participant Client\\n    participant Notification\\n    Note over Notification: Send welcome email\\n    Notification->>Client: Push notification to devices\\n\\n---\\nsequenceDiagram\\n    participant AuditLog\\n    Note over AuditLog: Record audit entry\\n\\n---\\nsequenceDiagram\\n    participant Client\\n    participant Error\\n    Note over Error: Handle API error\\n    Error->>Client: Return error response\\n"
`;

exports[`03 – Class (03-class-diagram-oop.py) > complete snapshot 1`] = `
"classDiagram\\n    class Address {\\n    +__init__ method()\\n    +Get Full Address()\\n    }\\n    class User {\\n    +__init__ method()\\n    +Add Address()\\n    +Get Default Address()\\n    +Place Order()\\n    }\\n    class Customer {\\n    +__init__ method()\\n    +Add To Wishlist()\\n    +Calculate Discount()\\n    }\\n    class Admin {\\n    +__init__ method()\\n    +Manage Product()\\n    }\\n    class Product {\\n    +__init__ method()\\n    +Update Stock()\\n    +Get Avg Rating()\\n    }\\n    class ShoppingCart {\\n    +__init__ method()\\n    +Add Item()\\n    +Get Subtotal()\\n    }\\n    class CartItem {\\n    +__init__ method()\\n    }\\n    class Order {\\n    +__init__ method()\\n    +Calculate Total()\\n    +Confirm()\\n    }\\n    class Review {\\n    +__init__ method()\\n    }\\n    User -- Address : has\\n    User --> Order : Place order\\n    User <|-- Customer : inherits\\n    Customer -- Product : wishlist\\n    User <|-- Admin : inherits\\n    Admin --> Product : Manage\\n    ShoppingCart -- Customer : belongs to\\n    ShoppingCart -- CartItem : contains\\n    CartItem -- Product : references\\n    Order -- Address : shipped to\\n    Review -- Customer : written by\\n    Review -- Product : reviews\\n"
`;

exports[`04 – State (04-state-machine-login.js) > complete snapshot 1`] = `
"stateDiagram-v2\\n    state LoggedOut {\\n        Showloginform: Show login form\\n    }\\n    state LoggingIn {\\n        Authenticate: Authenticate\\n    }\\n    state TwoFactorAuth {\\n        Verifycode: Verify code\\n    }\\n    state LoggedIn {\\n        Showdashboard: Show dashboard\\n        Logout: Logout\\n    }\\n    state AccountLocked {\\n        Showlockscreen: Show lock screen\\n        RequestUnlock: Request unlock email\\n    }\\n    state SessionExpired {\\n        Redirecttologin: Redirect to login\\n    }\\n    LoggedOut --> LoggingIn: Submit credentials\\n    LoggingIn --> TwoFactorAuth: Auth successful\\n    LoggingIn --> AccountLocked: Too many failed attempts\\n    LoggingIn --> LoggedOut: Invalid credentials (retry)\\n    TwoFactorAuth --> LoggedIn: 2FA valid\\n    TwoFactorAuth --> AccountLocked: Too many failed 2FA\\n    LoggedIn --> LoggedOut: Logout\\n    LoggedIn --> SessionExpired: Token expired\\n    AccountLocked --> LoggedOut: Unlock timeout\\n    SessionExpired --> LoggedOut: Redirect done\\n"
`;

exports[`05 – ER (05-er-database.sql) > complete snapshot 1`] = `
"erDiagram\\n    User {\\n        string id\\n        string name\\n        string email\\n        string phone\\n        string password_hash\\n        string avatar_url\\n        string two_factor_enabled\\n        string two_factor_secret\\n        string email_verified_at\\n        string locked_until\\n        string failed_attempts\\n        string loyalty_tier\\n        string loyalty_points\\n        string role\\n        string created_at\\n        string updated_at\\n        string deleted_at\\n    }\\n    Address {\\n        string id\\n        string user_id\\n        string label\\n        string street\\n        string number\\n        string complement\\n        string neighborhood\\n        string city\\n        string state\\n        string country\\n        string zip_code\\n        string is_default\\n        string created_at\\n    }\\n    Category {\\n        string id\\n        string name\\n        string slug\\n        string description\\n        string image_url\\n        string parent_id\\n        string sort_order\\n        string is_active\\n        string created_at\\n    }\\n    Product {\\n        string id\\n        string name\\n        string slug\\n        string description\\n        string short_description\\n        string price\\n        string compare_at_price\\n        string cost_price\\n        string sku\\n        string barcode\\n        string weight_kg\\n        string stock_quantity\\n        string min_stock_threshold\\n        string is_active\\n        string is_digital\\n        string created_at\\n        string updated_at\\n    }\\n    ProductCategory {\\n        string product_id\\n        string category_id\\n    }\\n    ProductImage {\\n        string id\\n        string product_id\\n        string url\\n        string alt_text\\n        string sort_order\\n        string is_primary\\n    }\\n    Order {\\n        string id\\n        string user_id\\n        string order_number\\n        string status\\n        string subtotal\\n        string discount_amount\\n        string shipping_cost\\n        string tax_amount\\n        string total\\n        string coupon_code\\n        string notes\\n        string shipping_address_id\\n        string billing_address_id\\n        string created_at\\n        string updated_at\\n    }\\n    OrderItem {\\n        string id\\n        string order_id\\n        string product_id\\n        string product_name\\n        string product_sku\\n        string unit_price\\n        string quantity\\n        string total_price\\n    }\\n    Payment {\\n        string id\\n        string order_id\\n        string method\\n        string status\\n        string amount\\n        string installments\\n        string gateway_transaction_id\\n        string gateway_response\\n        string paid_at\\n        string refunded_at\\n        string created_at\\n    }\\n    Shipping {\\n        string id\\n        string order_id\\n        string carrier\\n        string service_level\\n        string tracking_code\\n        string status\\n        string estimated_delivery\\n        string delivered_at\\n        string cost\\n        string created_at\\n        string updated_at\\n    }\\n    Review {\\n        string id\\n        string user_id\\n        string product_id\\n        string order_id\\n        string rating\\n        string title\\n        string comment\\n        string is_verified_purchase\\n        string is_approved\\n        string helpful_count\\n        string created_at\\n    }\\n    Session {\\n        string id\\n        string user_id\\n        string ip_address\\n        string user_agent\\n        string refresh_token\\n        string payload\\n        string last_activity\\n        string expires_at\\n        string created_at\\n    }\\n    AuditLog {\\n        string id\\n        string user_id\\n        string action\\n        string entity_type\\n        string entity_id\\n        string old_values\\n        string new_values\\n        string ip_address\\n        string user_agent\\n        string created_at\\n    }\\n    Coupon {\\n        string id\\n        string code\\n        string description\\n        string discount_type\\n        string discount_value\\n        string min_order_amount\\n        string max_uses\\n        string used_count\\n        string starts_at\\n        string expires_at\\n        string is_active\\n        string created_at\\n    }\\n    Cart {\\n        string id\\n        string user_id\\n        string session_token\\n        string created_at\\n        string updated_at\\n    }\\n    CartItem {\\n        string id\\n        string cart_id\\n        string product_id\\n        string quantity\\n        string added_at\\n    }\\n    Wishlist {\\n        string user_id\\n        string product_id\\n        string added_at\\n    }\\n    User ||--o{ Address : \\"has many\\"\\n    User ||--o{ Order : places\\n    User ||--o{ Review : writes\\n    User ||--o{ Session : has\\n    User ||--|| Cart : \\"has one\\"\\n    User ||--o{ Wishlist : \\"has many\\"\\n    User ||--o{ AuditLog : generates\\n    Category ||--o{ Category : \\"parent/child\\"\\n    Category ||--o{ ProductCategory : \\"belongs to\\"\\n    Product ||--o{ ProductCategory : \\"belongs to\\"\\n    Product ||--o{ ProductImage : \\"has many\\"\\n    Product ||--o{ Review : \\"has many\\"\\n    Product ||--o{ CartItem : \\"included in\\"\\n    Product ||--o{ Wishlist : \\"saved in\\"\\n    Order ||--o{ OrderItem : contains\\n    Order ||--|| Address : billing\\n    Order ||--|| Address : shipping\\n    Order ||--o{ Payment : \\"paid by\\"\\n    Order ||--o{ Shipping : \\"delivered via\\"\\n    Order ||--o{ Review : \\"reviewed in\\"\\n    Order ||--o{ Coupon : applied\\n    Product ||--o{ OrderItem : references\\n    Cart ||--o{ CartItem : contains\\n    Product ||--o{ CartItem : references\\n"
`;

exports[`06 – Sequence Steps (06-sequence-steps.js) > complete snapshot 1`] = `
"sequenceDiagram\\n    participant Provider\\n    participant Storage\\n    participant Database\\n    participant Notification\\n    Note over Provider: Upload document\\n    Provider->>Provider: Validate input\\n    Provider->>Provider: Build multipart body\\n    Provider->>Provider: Create HTTP Request\\n    Provider->>Storage: Save to S3\\n    Provider->>Database: Record metadata\\n    Provider->>Notification: Send confirmation\\n\\n---\\nsequenceDiagram\\n    participant Storage\\n    participant S3\\n    Note over Storage: Save file\\n    Storage->>S3: Upload with ACL\\n\\n---\\nsequenceDiagram\\n    participant Database\\n    Note over Database: Insert record\\n    Database->>Database: Validate schema\\n    Database->>Database: Execute INSERT\\n\\n---\\nsequenceDiagram\\n    participant Notification\\n    participant User\\n    Note over Notification: Notify user\\n    Notification->>User: Send email\\n\\n---\\nsequenceDiagram\\n    participant User\\n    Note over User: Receive notification\\n    User->>User: Display notification\\n"
`;