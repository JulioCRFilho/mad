# Source files (not needed at runtime — only ./out is)
src/**
test/**
*.ts
tsconfig.json

# Dev documentation and scripts
tasks.md
implementation_plan.md
implementation_plan_server.md
test-server.mjs
scripts/

# Dev tooling
.git/**
.gitignore
.envrc
node_modules/.cache/**

# Bundle only production node_modules (vsce prunes devDependencies)
# Exclude everything else at root and in node_modules
node_modules/**
!node_modules/mermaid/**
# mermaid is the only runtime dependency needed
